@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(SDL3 REQUIRED)
find_dependency(SDL3_mixer REQUIRED)
find_dependency(SDL3_image REQUIRED)
find_dependency(SDL3_ttf REQUIRED)
find_dependency(spdlog REQUIRED)
find_dependency(glm REQUIRED)
find_dependency(nlohmann_json REQUIRED)

set_and_check(ShitEngine_INCLUDE_DIR "@PACKAGE_CMAKE_INSTALL_INCLUDEDIR@")
set_and_check(ShitEngine_LIB_DIR     "@PACKAGE_CMAKE_INSTALL_LIBDIR@")

# 手动创建 imported target，不依赖 install(EXPORT)
add_library(ShitEngine::ShitEngine SHARED IMPORTED)

if(CMAKE_SYSTEM_NAME STREQUAL "Windows")
    set(_ShitEngine_LIB_NAME "ShitEngine.dll")
    set(_ShitEngine_IMPLIB_NAME "ShitEngine.lib")
elseif(CMAKE_SYSTEM_NAME STREQUAL "Darwin")
    set(_ShitEngine_LIB_NAME "libShitEngine.dylib")
    set(_ShitEngine_IMPLIB_NAME "")
else()
    set(_ShitEngine_LIB_NAME "libShitEngine.so")
    set(_ShitEngine_IMPLIB_NAME "")
endif()

set_target_properties(ShitEngine::ShitEngine PROPERTIES
    IMPORTED_LOCATION             "${ShitEngine_LIB_DIR}/${_ShitEngine_LIB_NAME}"
    IMPORTED_IMPLIB               "${ShitEngine_LIB_DIR}/${_ShitEngine_IMPLIB_NAME}"
    INTERFACE_INCLUDE_DIRECTORIES "${ShitEngine_INCLUDE_DIR}"
    INTERFACE_LINK_LIBRARIES      "SDL3::SDL3;SDL3_mixer::SDL3_mixer;SDL3_image::SDL3_image;SDL3_ttf::SDL3_ttf;spdlog::spdlog;glm::glm;nlohmann_json::nlohmann_json"
)

check_required_components(ShitEngine)
