@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(SDL3 REQUIRED)
find_dependency(SDL3_mixer REQUIRED)
find_dependency(SDL3_image REQUIRED)
find_dependency(SDL3_ttf REQUIRED)
find_dependency(spdlog REQUIRED)
find_dependency(glm REQUIRED)
find_dependency(nlohmann_json REQUIRED)

include("${CMAKE_CURRENT_LIST_DIR}/ShitEngineTargets.cmake")

check_required_components(ShitEngine)
